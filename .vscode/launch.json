{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Helm Desktop (dev)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"],
      "env": {
        "ELECTRON_DEV_TOOLS": "true"
      }
    },
    {
      "name": "Launch Go Program",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${fileDirname}",
      "env": {},
      "args": [],
      "showLog": false,
      "logOutput": "dap",
    }
  ]
}
